#include "hlpfuncs.h"
#include <stdbool.h>
#include <stdlib.h>
#include <string.h>
#include <sys/types.h>
#include <sys/wait.h>
#include <unistd.h>

void cmd_exe(char **input, bool background) {
  pid_t pid = fork();

  if (pid == 0) {
    execvp(input[0], input);

  } else {
    if (background==true) {
      printf("background");
    } else {
      int status;

      waitpid(pid, &status, 0);
    }
  }
}
