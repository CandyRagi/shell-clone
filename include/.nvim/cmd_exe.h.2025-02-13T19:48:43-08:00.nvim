#include "hlpfuncs.h"
#include <stdbool.h>
#include <stdlib.h>
#include <string.h>
#include <sys/types.h>
#include <sys/wait.h>
#include <unistd.h>

void cmd_exe(char **input, bool background) {
  pid_t pid = fork();

  if (pid == 0) {
    execvp(input[0], input);
    write(STDERR_FILENO, "excecvp failed\n", 15);

  } else {
    if (!background) {
    
      int status;

      waitpid(pid, &status, 0);
    }
  }
}
