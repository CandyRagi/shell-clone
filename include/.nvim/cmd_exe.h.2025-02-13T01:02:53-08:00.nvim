#include <sys/types.h>
#include <sys/wait.h>
#include<unistd.h>
#include<stdlib.h>
#include<string.h>


void cmd_exe(char **input) {
  pid_t pid = fork();

  if (pid == 0) {
    execvp(input[0], input);

  } else {

    if (isBackgroundprocess(input)) {

    } else {
      int status;

      waitpid(pid, &status, 0);
    }
  }
}
