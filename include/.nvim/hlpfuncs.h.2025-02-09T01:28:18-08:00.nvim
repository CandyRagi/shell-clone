#include "msgs.h"
#include <stdio.h>
#include <stdlib.h>

int signal_safe_strlen(char *input) {
  size_t len = 0;
  while (input[len] != '\0') {
    len++;
  }
  return len;
}

void get_input(char*input)
{
  size_t input_size=1024;
  input=(char*)malloc(input_size);

  if(input==NULL)
  {
    write(STDERR_FILENO,"Input failed\n",13);
    return;
  }


}
